        </mxCell>
        <mxCell id="p2_b4" value="&lt;b&gt;AuditRouter.Emit&lt;/b&gt;&#xa;ModbusAuditEvent&#xa;one event per operation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="580" y="305" width="150" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="p2_b5" value="&lt;b&gt;Return Result&lt;/b&gt;&#xa;Success / Error&#xa;+ Diagnostics" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="760" y="305" width="150" height="60" as="geometry"/>
        </mxCell>
