        <mxCell id="p5_sub" value="Every Read, Write, and Admin operation emits exactly one ModbusAuditEvent. Sink is selected once at startup from the ModbusTcp.AuditSink environment variable." style="text;html=1;fontSize=11;fontStyle=2;align=center;" vertex="1" parent="1">
