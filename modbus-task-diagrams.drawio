        </mxCell>
        <mxCell id="p2_err_guard" value="InvalidOperationException&#xa;(no socket opened)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
