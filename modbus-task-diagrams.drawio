        </mxCell>
        <mxCell id="p2_e_guard_err" value="blocked" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" edge="1" source="p2_a2" target="p2_err_guard" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="p2_e_breaker_err" value="Open" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;" edge="1" source="p2_a3" target="p2_err_breaker" parent="1">
