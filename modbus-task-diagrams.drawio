        <mxCell id="p2_b3" value="&lt;b&gt;ModbusLease.Dispose&lt;/b&gt;&#xa;success: Release&#xa;error: Poison + Remove" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
