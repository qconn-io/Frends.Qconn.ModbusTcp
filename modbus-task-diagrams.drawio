          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="p4_miss_connect" value="&lt;b&gt;ModbusConnection.ConnectAsync&lt;/b&gt;&#xa;new TcpClient + IModbusMaster&#xa;(ConnectTimeoutMs)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="320" width="200" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="p4_miss_add" value="&lt;b&gt;new PooledConnection&lt;/b&gt;&#xa;ConcurrentDictionary.TryAdd&#xa;SemaphoreSlim(1,1) attached" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="440" width="200" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="p4_e_d1_miss" value="Miss" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="p4_d1" target="p4_miss_connect" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="p4_e_miss1" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="p4_miss_connect" target="p4_miss_add" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="p4_sema" value="&lt;b&gt;SemaphoreSlim.WaitAsync&lt;/b&gt;&#xa;(AcquireTimeoutMs)&#xa;serialises req/resp per connection" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="280" y="560" width="220" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="p4_e_d1_hit" value="Hit" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="p4_d1" target="p4_sema" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="p4_e_miss_sema" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="p4_miss_add" target="p4_sema" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="p4_bp" value="&lt;b&gt;ErrorCategory.Backpressure&lt;/b&gt;&#xa;AcquireTimeoutMs exceeded&#xa;(no socket attempt)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="560" y="560" width="200" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="p4_e_sema_bp" value="Timeout" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#b85450;fontColor=#b85450;" edge="1" source="p4_sema" target="p4_bp" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="p4_lease" value="&lt;b&gt;ModbusLease issued&lt;/b&gt;&#xa;IModbusMaster exposed&#xa;CancellationToken registered" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="280" y="680" width="220" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="p4_e_sema_lease" value="OK" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="p4_sema" target="p4_lease" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="p4_op" value="[caller executes Modbus operation]" style="text;html=1;fontSize=11;fontStyle=2;align=center;" vertex="1" parent="1">
          <mxGeometry x="240" y="768" width="300" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="p4_d2" value="&lt;b&gt;DisposeAsync:&#xa;Poison=true?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="280" y="800" width="220" height="80" as="geometry"/>
        </mxCell>
