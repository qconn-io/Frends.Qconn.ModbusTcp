        </mxCell>
        <mxCell id="p2_retry_bg" value="Retry Loop (per MaxAttempts)" style="rounded=0;whiteSpace=wrap;html=1;dashed=1;fillColor=none;strokeColor=#aaaaaa;verticalAlign=top;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="20" y="290" width="580" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="p2_b1" value="&lt;b&gt;ConnectionPool&lt;/b&gt;&#xa;AcquireAsync(key)&#xa;per-device TCP reuse" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="305" width="150" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="p2_b2" value="&lt;b&gt;Execute Modbus&lt;/b&gt;&#xa;IModbusMaster&#xa;FC01-FC23 via NModbus" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
