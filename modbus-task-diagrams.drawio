        </mxCell>
        <mxCell id="p2_e6" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="p2_b3" target="p2_b4" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="p2_e7" value="" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="p2_b4" target="p2_b5" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="p2_note" value="&lt;b&gt;Breaker feedback:&lt;/b&gt; ModbusLease.Dispose calls BreakerRegistry.RecordSuccess() or RecordFailure(). Modbus exception codes 1/2/3 (client bugs) never count as failures. Codes 4/5/6/10/11 count." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="410" width="870" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="p2_telemetry" value="&lt;b&gt;Telemetry (throughout):&lt;/b&gt; Meter counters modbus.operations, modbus.errors, modbus.retry.count, modbus.backpressure.rejected incremented at each step. ActivitySource span wraps the full operation." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="460" width="870" height="40" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="d3" name="3 - Circuit Breaker">
    <mxGraphModel adaptiveColors="auto">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="p3_ttl" value="Circuit Breaker State Machine" style="text;html=1;fontSize=18;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="760" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="p3_sub" value="One breaker per ConnectionKey (Host + Port + UnitId). Default: FailureThreshold=5, OpenDurationMs=30000, SuccessThresholdToClose=1." style="text;html=1;fontSize=11;fontStyle=2;align=center;" vertex="1" parent="1">
          <mxGeometry x="40" y="50" width="760" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="p3_closed" value="&lt;b&gt;CLOSED&lt;/b&gt;&#xa;Normal operation&#xa;Requests pass through" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="80" y="180" width="220" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="p3_open" value="&lt;b&gt;OPEN&lt;/b&gt;&#xa;All requests short-circuit&#xa;Returns CircuitOpen error instantly" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="540" y="180" width="220" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="p3_half" value="&lt;b&gt;HALF-OPEN&lt;/b&gt;&#xa;One probe request allowed&#xa;Tests device recovery" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="310" y="400" width="220" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="p3_t1" value="&gt;= FailureThreshold consecutive&#xa;device failures (codes 4/5/6/10/11)" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#b85450;fontColor=#b85450;fontSize=10;" edge="1" source="p3_closed" target="p3_open" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="p3_t2" value="OpenDurationMs elapsed&#xa;(default 30 s)" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#d6b656;fontColor=#8a5a00;fontSize=10;" edge="1" source="p3_open" target="p3_half" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="p3_t3" value="Probe success&#xa;(SuccessThresholdToClose met)" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#82b366;fontColor=#2a6b2a;fontSize=10;" edge="1" source="p3_half" target="p3_closed" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="p3_t4" value="Probe failure" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#b85450;fontColor=#b85450;fontSize=10;" edge="1" source="p3_half" target="p3_open" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="p3_n1" value="&lt;b&gt;Counts as failure:&lt;/b&gt; Modbus device codes 4 (SlaveDeviceFailure), 5 (Acknowledge), 6 (SlaveDeviceBusy), 10 (GatewayPathUnavailable), 11 (GatewayTargetDeviceFailed). Also: Timeout, ConnectionRefused, SocketError." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="540" width="320" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="p3_n2" value="&lt;b&gt;Does NOT count:&lt;/b&gt; Modbus client-bug codes 1 (IllegalFunction), 2 (IllegalDataAddress), 3 (IllegalDataValue). These indicate a logic error in the Task configuration, not a device failure." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="440" y="540" width="320" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="p3_n3" value="Set &lt;b&gt;Options.CircuitBreaker.Enabled=false&lt;/b&gt; to disable the breaker for a specific Task call. Set &lt;b&gt;Admin.ResetCircuit&lt;/b&gt; to manually reset from OPEN to CLOSED (audit-logged)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="630" width="680" height="40" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="d4" name="4 - Connection Pool">
    <mxGraphModel adaptiveColors="auto">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="p4_ttl" value="Connection Pool — AcquireAsync Lifecycle" style="text;html=1;fontSize=18;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="760" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="p4_sub" value="Agent-wide pool keyed by (Host, Port, UnitId, TransportMode). Default: MaxConnectionsPerDevice=1, IdleTimeoutMs=60000, AcquireTimeoutMs=5000." style="text;html=1;fontSize=11;fontStyle=2;align=center;" vertex="1" parent="1">
          <mxGeometry x="40" y="50" width="760" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="p4_entry" value="&lt;b&gt;AcquireAsync(key, options, ct)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="260" y="90" width="270" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="p4_d1" value="&lt;b&gt;TryGetValue(key)?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
