        <mxCell id="p1_c5" value="&lt;b&gt;Admin (v2)&lt;/b&gt;&#xa;PoolStatistics&#xa;CircuitState&#xa;ResetCircuit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=10;" vertex="1" parent="1">
