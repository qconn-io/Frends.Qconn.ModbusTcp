        <mxCell id="p4_evict" value="&lt;b&gt;Background Eviction Timer (30 s interval)&lt;/b&gt;&#xa;Removes connections idle &gt; IdleTimeoutMs (default 60 s).&#xa;Hooks: AppDomain.ProcessExit + AssemblyLoadContext.Unloading." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontSize=10;" vertex="1" parent="1">
